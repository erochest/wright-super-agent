<div class="profile-layout">
<div class="card">

  <!-- STRIP: Diagnostic bar / bio-strip / terminal prompt -->
  {# STRIP: Generate the top strip based on the theme config strip.type:
     - type "text": <div class="strip strip--text"><span>{left}</span><span class="strip-right">{right}</span></div>
     - type "gradient": <div class="strip" style="background:{gradient}"></div>
     - type "solid": <div class="strip" style="background:{color}"></div>
  }

  <!-- HEADER IMAGE: AI-generated archetype art -->
  {# HEADER_IMAGE: If theme config has headerImage, generate:
     <img class="header-image" src="{generated_image_path}" alt="{NAME} header art">
     If no image available, use: <div class="header-image-placeholder"></div>
  }

  <div class="card-body">

    <!-- HEADER -->
    <div>
      <div class="name">{NAME}</div>
      <div class="subtitle">{SUBTITLE}</div>
    </div>

    <!-- BADGES with hover tooltips -->
    <div class="badges">
      <span class="badge badge-domain">
        <span class="icon"><svg><use href="#icon-{THEME_ICON_DOMAIN}"/></svg></span>
        {DOMAIN_BADGE}
        <span class="tooltip">{DOMAIN_TOOLTIP}</span>
      </span>
      <span class="badge badge-authority">
        <span class="icon"><svg><use href="#icon-{THEME_ICON_AUTHORITY}"/></svg></span>
        {AUTHORITY_MODEL}
        <span class="tooltip">{AUTHORITY_TOOLTIP}</span>
      </span>
      <span class="badge badge-trust">
        <span class="icon"><svg><use href="#icon-{THEME_ICON_TRUST}"/></svg></span>
        {TRUST_BADGE}
        <span class="tooltip">{TRUST_TOOLTIP}</span>
      </span>
    </div>

    <!-- PERSONALITY PROFILE: Trait bars -->
    <div class="section" data-section="personality">
      <div class="section-title">{THEME_SECTION_TRAITS}</div>
      <div class="section-divider"></div>
      {# TRAIT_BARS: Generate a trait row for each trait using this structure:

         <div class="trait-row">
           <span class="trait-label">TRAIT_NAME</span>
           <div class="trait-bar">
             <div class="trait-fill" style="--target-width: {score/5 * 100}%"></div>
           </div>
           <span class="trait-score">{score}</span>
         </div>

         Use the trait names and scores from the interview.
      }
    </div>

    <!-- SAMPLE SPEECH -->
    <div class="section" data-section="voice">
      <div class="section-title">{THEME_SECTION_VOICE}</div>
      <div class="section-divider"></div>
      {# SPEECH_SAMPLES: Generate 2-3 speech blocks using this structure:

         <div class="speech">
           <div class="speech-label">On [scenario]</div>
           <div class="speech-quote">"[In-character quote]"</div>
         </div>

         Scenarios: one technical, one collaborative, one boundary-testing.
         Voice must match the interview's speech patterns and be distinct from C-3PO.
      }
    </div>

    <!-- GOALS -->
    <div class="section" data-section="goals">
      <div class="section-title">{THEME_SECTION_GOALS}</div>
      <div class="section-divider"></div>
      {# GOALS_SUMMARY: Generate a goal card for each goal:

         <div class="goal">
           <div class="goal-title">[Goal Name]</div>
           <div class="goal-detail">
             <strong>Purpose:</strong> [purpose]<br>
             <strong>End State:</strong> [end_state]<br>
             <strong>Appetite:</strong> [appetite]<br>
             <strong>No-gos:</strong> [no_gos]
           </div>
         </div>
      }
    </div>

    <div class="footer">
      Generated by /create-agent in C-3PO &middot; Super Agent Doctrine (ADR-003)
    </div>
  </div>
</div>

<!-- ANNOTATION PANEL -->
<div class="panel">
  <div class="panel-title">{THEME_PANEL_TITLE}</div>
  <div style="height:1px;background:var(--card-border)"></div>
  <div class="panel-hint">
    Click any section on the card to add notes.
    Annotations are saved with the profile for review.
  </div>
  <div class="panel-notes">
    {# ANNOTATIONS: Pre-populate with 1-2 example annotations:

       <div class="note note-enter">
         <button class="note-delete" title="Remove annotation">&times;</button>
         <div class="note-tag">[SECTION_NAME]</div>
         <div class="note-body">[Example observation about this section]</div>
       </div>
    }
  </div>
  <div class="panel-actions">
    <button class="btn btn-primary btn-export">COPY REVIEW</button>
  </div>
</div>
</div>

<script>
  // Animate trait bars on load
  requestAnimationFrame(() => {
    document.querySelector('.profile-layout').classList.add('loaded');
  });

  // --- Annotation System ---
  const annotations = [];
  const notesContainer = document.querySelector('.panel-notes');
  const sections = document.querySelectorAll('.section[data-section]');
  let activeForm = null;

  // Click section to annotate
  sections.forEach(section => {
    section.addEventListener('click', (e) => {
      if (e.target.closest('.annotation-form')) return;
      const sectionName = section.dataset.section;
      closeAnnotationForm();
      sections.forEach(s => s.classList.remove('annotating'));
      section.classList.add('annotating');

      const form = document.createElement('div');
      form.className = 'annotation-form';
      form.innerHTML = `
        <div class="annotation-form-header">
          <span class="annotation-form-section">${sectionName.toUpperCase()}</span>
          <button class="annotation-form-close">&times;</button>
        </div>
        <textarea class="annotation-textarea" placeholder="Add a note about ${sectionName}..."></textarea>
        <button class="annotation-submit">ADD NOTE</button>
      `;

      const actions = document.querySelector('.panel-actions');
      actions.parentNode.insertBefore(form, actions);
      activeForm = form;
      form.querySelector('.annotation-textarea').focus();

      form.querySelector('.annotation-form-close').addEventListener('click', closeAnnotationForm);

      form.querySelector('.annotation-submit').addEventListener('click', () => {
        const body = form.querySelector('.annotation-textarea').value.trim();
        if (!body) return;
        addAnnotation(sectionName, body);
        closeAnnotationForm();
      });

      form.querySelector('.annotation-textarea').addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
          form.querySelector('.annotation-submit').click();
        }
      });
    });
  });

  function closeAnnotationForm() {
    if (activeForm) { activeForm.remove(); activeForm = null; }
    sections.forEach(s => s.classList.remove('annotating'));
  }

  function addAnnotation(section, body) {
    const annotation = { section, body, timestamp: new Date().toISOString() };
    annotations.push(annotation);
    const note = document.createElement('div');
    note.className = 'note note-enter';
    const del = document.createElement('button');
    del.className = 'note-delete';
    del.title = 'Remove annotation';
    del.innerHTML = '&times;';
    const tag = document.createElement('div');
    tag.className = 'note-tag';
    tag.textContent = section.toUpperCase();
    const bodyEl = document.createElement('div');
    bodyEl.className = 'note-body';
    bodyEl.textContent = body;
    note.append(del, tag, bodyEl);
    notesContainer.appendChild(note);
    bindNoteDelete(note, annotation);
  }

  function bindNoteDelete(noteEl, annotation) {
    noteEl.querySelector('.note-delete').addEventListener('click', () => {
      noteEl.remove();
      if (annotation) {
        const idx = annotations.indexOf(annotation);
        if (idx > -1) annotations.splice(idx, 1);
      }
    });
  }

  // Bind delete on pre-existing notes
  document.querySelectorAll('.note .note-delete').forEach(btn => {
    btn.addEventListener('click', () => btn.closest('.note').remove());
  });

  // Export — copy annotations JSON to clipboard
  document.querySelector('.btn-export').addEventListener('click', () => {
    const exportData = {
      agent: document.querySelector('.name').textContent,
      sessionFile: '.local/create-agent-session.yml',
      annotations: annotations
    };
    navigator.clipboard.writeText(JSON.stringify(exportData, null, 2)).then(() => {
      const btn = document.querySelector('.btn-export');
      const original = btn.textContent;
      btn.textContent = 'COPIED';
      setTimeout(() => btn.textContent = original, 1500);
    });
  });
</script>

</body>
</html>
