name: Wiki Audit

on:
  schedule:
    - cron: '0 9 * * 1'
  workflow_dispatch:

concurrency:
  group: wiki-garden
  cancel-in-progress: false

permissions:
  contents: write
  issues: write

jobs:
  wiki-audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0

      - uses: fuelix/arden-wiki-garden-action@v1
        with:
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          max_turns: 100
          mode: audit
