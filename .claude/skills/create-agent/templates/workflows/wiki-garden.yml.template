name: Wiki Garden

on:
  pull_request:
    types: [closed]

concurrency:
  group: wiki-garden
  cancel-in-progress: false

permissions:
  contents: write
  pull-requests: write
  issues: write

jobs:
  wiki-sync:
    runs-on: ubuntu-latest
    if: github.event.pull_request.merged == true
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0

      - uses: fuelix/arden-wiki-garden-action@v1
        with:
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          max_turns: 100
